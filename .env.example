# .env.example
# Copy this to .env and fill in real values. Never commit .env.

# Gateway
GATEWAY_PORT=8080
GATEWAY_JWT_SECRET=your-secret-here

# Trip Service
TRIP_HTTP_PORT=8082
TRIP_GRPC_PORT=50051
TRIP_LOG_LEVEL=info
TRIP_SHUTDOWN_TIMEOUT_SEC=10
TRIP_MONGO_URI=mongodb://localhost:27017
TRIP_MONGO_DB=rideshare_trip

# Driver Service  
DRIVER_PORT=50052
DRIVER_MONGO_URI=mongodb://localhost:27017
DRIVER_MONGO_DB=rideshare_driver

# Payment Service
PAYMENT_PORT=50053
PAYMENT_MONGO_URI=mongodb://localhost:27017
PAYMENT_MONGO_DB=rideshare_payment
PAYMENT_STRIPE_SECRET_KEY=sk_test_...
PAYMENT_STRIPE_WEBHOOK_SECRET=whsec_...

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Jaeger
JAEGER_ENDPOINT=http://localhost:14268/api/traces
```

This file is committed. The real `.env` is not.

